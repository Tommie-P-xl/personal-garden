---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { scanNotes, getAllFlatNotes } from '../../lib/scan-notes';
import { registerSlug } from '../../lib/slug-hash';

const base = import.meta.env.BASE_URL;

const tree = scanNotes();
const allFlatNotes = getAllFlatNotes();

// 获取所有标签（搜索用）
const allTags = [...new Set(allFlatNotes.flatMap(note => note.tags))];

// 按频率排序标签，只显示前20个
const tagFrequency: Record<string, number> = {};
allFlatNotes.forEach(note => {
  note.tags.forEach(tag => {
    tagFrequency[tag] = (tagFrequency[tag] || 0) + 1;
  });
});
const displayTags = Object.entries(tagFrequency)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 20)
  .map(([tag]) => tag);

// 一级分类（只展示顶层目录）
const topCategories = tree.filter(item => item.type === 'dir');
---

<BaseLayout title="笔记">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2 flex items-center gap-2">
      <img src={`${base}icons/笔记.svg`} alt="" class="w-6 h-6 icon-dark-adapt" />
      笔记
    </h1>
    <p class="text-gray-500 dark:text-gray-400">在这里记录学习的点滴，让知识像花园一样生长</p>
  </div>

  <!-- 搜索栏 -->
  <div class="mb-6">
    <div class="relative">
      <input
        type="text"
        id="search-input"
        placeholder="搜索笔记标题、内容、标签..."
        class="w-full px-4 py-3 pl-10 bg-white/60 dark:bg-[#141827]/60 backdrop-blur-xl border border-gray-200/50 dark:border-white/[0.06] rounded-xl text-gray-900 dark:text-white placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:border-garden-400 dark:focus:border-garden-500 focus:ring-2 focus:ring-garden-100/50 dark:focus:ring-garden-900/20 transition-all"
      />
      <svg class="absolute left-3 top-3.5 w-4 h-4 text-gray-400 dark:text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
    </div>
  </div>

  <!-- 笔记大类 -->
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8" id="categories-grid">
    {topCategories.map((cat) => {
      const hashedSlug = registerSlug(cat.slug);
      return (
      <a
        href={`${base}garden/${hashedSlug}/`}
        class="category-item block bg-white/60 dark:bg-[#141827]/60 backdrop-blur-xl rounded-xl border border-gray-200/50 dark:border-white/[0.06] p-6 hover:shadow-md hover:border-garden-300/60 dark:hover:border-garden-700/30 transition-all duration-300 group"
        data-name={cat.meta?.title || cat.title}
      >
        <div class="flex items-center gap-3 mb-2">
          <img src={`${base}icons/文件夹.svg`} alt="" class="w-5 h-5 icon-colorful" />
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white group-hover:text-garden-600 dark:group-hover:text-garden-400 transition-colors">
            {cat.meta?.title || cat.title}
          </h3>
        </div>
        {cat.meta?.description && (
          <p class="text-sm text-gray-500 dark:text-gray-400">{cat.meta.description}</p>
        )}
        <div class="mt-3 text-xs text-gray-400 dark:text-gray-500">
          {(() => {
            let count = 0;
            function countFiles(items) {
              for (const item of items) {
                if (item.type === 'file') count++;
                else if (item.children) countFiles(item.children);
              }
            }
            countFiles(cat.children || []);
            return count;
          })()} 篇笔记
        </div>
      </a>
      );
    })}
  </div>

  <!-- 标签云 -->
  {displayTags.length > 0 && (
    <div class="mb-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">标签</h2>
      <div class="flex flex-wrap gap-2" id="tag-filter">
        {displayTags.map((tag) => (
          <button
            data-tag={tag}
            class="px-3 py-1 bg-gray-100/60 dark:bg-white/[0.05] backdrop-blur-sm text-gray-600 dark:text-gray-300 rounded-lg text-xs hover:bg-garden-50 dark:hover:bg-garden-900/20 hover:text-garden-700 dark:hover:text-garden-400 transition-colors whitespace-nowrap border border-gray-200/40 dark:border-white/[0.04]"
          >
            #{tag}
          </button>
        ))}
      </div>
    </div>
  )}

  <!-- 搜索结果（隐藏，搜索时显示） -->
  <div id="search-results" class="hidden">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-3">搜索结果</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4" id="search-results-grid"></div>
    <div id="search-empty" class="hidden text-center py-8">
      <p class="text-gray-500 dark:text-gray-400">没有找到匹配的笔记</p>
    </div>
  </div>

  <script is:inline define:vars={{ notesJson: JSON.stringify(allFlatNotes.map(n => ({ title: n.title, slug: registerSlug(n.slug), tags: n.tags, summary: n.summary || '', category: n.category }))) }}>
    (function() {
      var notesData = JSON.parse(notesJson);
      var activeTag = null;

      function esc(str) {
        var div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
      }

      function getBase() {
        var baseEl = document.querySelector('base');
        return baseEl ? baseEl.href : '/';
      }

      function doSearch(term) {
        term = (term || '').toLowerCase();
        var hasSearch = term.length > 0 || activeTag;

        var categoriesGrid = document.getElementById('categories-grid');
        var searchResults = document.getElementById('search-results');
        var searchResultsGrid = document.getElementById('search-results-grid');
        var searchEmpty = document.getElementById('search-empty');

        if (!hasSearch) {
          categoriesGrid && categoriesGrid.classList.remove('hidden');
          searchResults && searchResults.classList.add('hidden');
          return;
        }

        categoriesGrid && categoriesGrid.classList.add('hidden');
        searchResults && searchResults.classList.remove('hidden');

        var results = notesData.filter(function(n) {
          var matchesTag = !activeTag || n.tags.includes(activeTag);
          var matchesSearch = !term ||
            n.title.toLowerCase().includes(term) ||
            n.summary.toLowerCase().includes(term) ||
            n.tags.some(function(t) { return t.toLowerCase().includes(term); });
          return matchesTag && matchesSearch;
        });

        var base = getBase();
        if (searchResultsGrid) {
          if (results.length === 0) {
            searchResultsGrid.innerHTML = '';
            searchEmpty && searchEmpty.classList.remove('hidden');
          } else {
            searchEmpty && searchEmpty.classList.add('hidden');
            searchResultsGrid.innerHTML = results.map(function(n) {
              var tagsHtml = '';
              if (n.tags.length > 0) {
                tagsHtml = '<div class="flex gap-1 mt-2 flex-wrap">' +
                  n.tags.slice(0,3).map(function(t) {
                    return '<span class="bg-gray-50/80 dark:bg-white/[0.04] px-2 py-0.5 rounded-md text-xs text-gray-500 dark:text-gray-400 border border-gray-200/50 dark:border-white/[0.06]">#' + esc(t) + '</span>';
                  }).join('') + '</div>';
              }
              return '<a href="' + esc(base) + 'garden/' + esc(n.slug) + '/"' +
                ' class="block bg-white/60 dark:bg-[#141827]/60 backdrop-blur-xl rounded-xl border border-gray-200/50 dark:border-white/[0.06] p-4 hover:shadow-md hover:border-garden-300/60 dark:hover:border-garden-700/30 transition-all duration-300 group">' +
                '<div class="flex items-center gap-2 mb-1">' +
                '<span class="text-xs text-gray-400 dark:text-gray-500">' + esc(n.category) + '</span></div>' +
                '<h3 class="font-medium text-gray-900 dark:text-white group-hover:text-garden-600 dark:group-hover:text-garden-400 transition-colors line-clamp-2 mb-1">' + esc(n.title) + '</h3>' +
                (n.summary ? '<p class="text-xs text-gray-500 dark:text-gray-400 line-clamp-2">' + esc(n.summary) + '</p>' : '') +
                tagsHtml + '</a>';
            }).join('');
          }
        }
      }

      // 暴露为全局函数，供 BaseLayout 事件委托调用
      window.__gardenSearch = doSearch;

      window.__gardenTagFilter = function(btn) {
        var tag = btn.dataset.tag || '';
        activeTag = activeTag === tag ? null : tag;

        var tagButtons = document.querySelectorAll('#tag-filter button');
        tagButtons.forEach(function(b) {
          var isActive = b.dataset.tag === activeTag;
          b.className = isActive
            ? 'px-3 py-1 bg-garden-600 dark:bg-garden-700 text-white rounded-lg text-xs transition-colors whitespace-nowrap'
            : 'px-3 py-1 bg-gray-100/60 dark:bg-white/[0.05] text-gray-600 dark:text-gray-300 rounded-lg text-xs hover:bg-garden-50 dark:hover:bg-garden-900/20 hover:text-garden-700 dark:hover:text-garden-400 transition-colors whitespace-nowrap border border-gray-200/40 dark:border-white/[0.04]';
        });

        var searchInput = document.getElementById('search-input');
        doSearch(searchInput ? searchInput.value : '');
      };
    })();
  </script>
</BaseLayout>
