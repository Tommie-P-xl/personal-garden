---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { scanNotes, getAllFlatNotes } from '../lib/scan-notes';
import { enrichWithStars } from '../lib/github';
import { registerSlug } from '../lib/slug-hash';

const base = import.meta.env.BASE_URL;

// 一级分类（只展示顶层目录）
const tree = scanNotes();
const topCategories = tree.filter(item => item.type === 'dir');

const allProjectsRaw = await getCollection('projects');
const allProjectsWithStars = await enrichWithStars(allProjectsRaw);

const featuredProjects = allProjectsWithStars
  .filter(p => p.data.featured)
  .sort((a, b) => {
    if (b.stars !== a.stars) return b.stars - a.stars;
    return b.data.date.valueOf() - a.data.date.valueOf();
  })
  .slice(0, 4);

// 从笔记和项目中提取所有标签，按频率排序
const allFlatNotes = getAllFlatNotes();

const tagFrequency: Record<string, number> = {};
allFlatNotes.forEach(note => {
  note.tags.forEach(tag => {
    tagFrequency[tag] = (tagFrequency[tag] || 0) + 1;
  });
});
allProjectsWithStars.forEach(project => {
  project.data.tech.forEach(tech => {
    tagFrequency[tech] = (tagFrequency[tech] || 0) + 1;
  });
});

const sortedTags = Object.entries(tagFrequency)
  .sort((a, b) => b[1] - a[1])
  .map(([tag]) => tag);

const displayTags = sortedTags.slice(0, 20);
---

<BaseLayout title="首页">
  <!-- 个人介绍 -->
  <section class="mb-12">
    <div class="bg-white/50 dark:bg-[#18181b]/60 backdrop-blur-sm rounded-2xl border border-gray-200/60 dark:border-white/[0.06] p-8">
      <div class="flex flex-col sm:flex-row items-start gap-6">
        <img
          src={`${base}images/avatar.jpg`}
          alt="Tommie-P-xl"
          class="w-20 h-20 rounded-full object-cover flex-shrink-0 ring-2 ring-gray-100 dark:ring-white/10"
        />
        <div class="flex-1">
          <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-1 tracking-tight">Tommie-P-xl</h1>
          <p class="text-base text-gray-500 dark:text-gray-400 mb-5">AI Agent & Embedded AI Development Enthusiast</p>
          <div class="flex flex-wrap gap-2">
            <button
              type="button"
              class="copy-btn inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-100/70 dark:bg-white/[0.06] backdrop-blur-sm rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-garden-50 dark:hover:bg-garden-900/20 hover:text-garden-700 dark:hover:text-garden-400 transition-colors cursor-pointer"
              data-copy="wux4948@gmail.com"
            >
              <img src={`${base}icons/email.svg`} alt="Email" class="w-4 h-4 dark:invert" />
              Mail
            </button>
            <a href="https://github.com/Tommie-P-xl" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-100/70 dark:bg-white/[0.06] backdrop-blur-sm rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-gray-200/60 dark:hover:bg-white/[0.1] transition-colors">
              <img src={`${base}icons/github.svg`} alt="GitHub" class="w-4 h-4 dark:invert" />
              GitHub
            </a>
            <button
              type="button"
              class="copy-btn inline-flex items-center gap-1.5 px-3 py-1.5 bg-gray-100/70 dark:bg-white/[0.06] backdrop-blur-sm rounded-lg text-sm text-gray-600 dark:text-gray-300 hover:bg-garden-50 dark:hover:bg-garden-900/20 hover:text-garden-700 dark:hover:text-garden-400 transition-colors cursor-pointer"
              data-copy="w9519539"
            >
              <img src={`${base}icons/wechat.svg`} alt="WeChat" class="w-4 h-4 dark:invert" />
              WeChat
            </button>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 教育背景 & 技术栈 -->
  <section class="grid sm:grid-cols-3 gap-6 mb-12">
    <!-- 教育背景 - 占1列 -->
    <div class="bg-white/50 dark:bg-[#18181b]/60 backdrop-blur-sm rounded-xl border border-gray-200/60 dark:border-white/[0.06] p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
        <img src={`${base}icons/学术帽.svg`} alt="" class="w-5 h-5 icon-dark-adapt" />
        教育背景
      </h2>
      <div class="space-y-4">
        <div>
          <a href="https://www.zjut.edu.cn/" target="_blank" rel="noopener noreferrer" class="font-medium text-gray-900 dark:text-white hover:text-garden-600 dark:hover:text-garden-400 transition-colors">
            浙江工业大学
          </a>
          <div class="text-sm text-gray-500 dark:text-gray-400">通信工程 · 本科</div>
          <div class="text-xs text-gray-400 dark:text-gray-500 mt-1">2022.09 - 2026.06</div>
        </div>
        <div class="border-t border-gray-100 dark:border-white/[0.06] pt-4">
          <a href="https://www.uestc.edu.cn/" target="_blank" rel="noopener noreferrer" class="font-medium text-gray-900 dark:text-white hover:text-garden-600 dark:hover:text-garden-400 transition-colors">
            电子科技大学
          </a>
          <div class="text-sm text-gray-500 dark:text-gray-400">电子信息 · 专硕</div>
          <div class="text-xs text-gray-400 dark:text-gray-500 mt-1">2026.09 - 2029.06</div>
        </div>
      </div>
    </div>

    <!-- 技术栈 - 占2列 -->
    <div class="sm:col-span-2 bg-white/50 dark:bg-[#18181b]/60 backdrop-blur-sm rounded-xl border border-gray-200/60 dark:border-white/[0.06] p-6">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
        <img src={`${base}icons/终端.svg`} alt="" class="w-5 h-5 icon-dark-adapt" />
        Keys
      </h2>
      <div class="flex flex-wrap gap-2" id="tech-tags-container">
        {displayTags.map((tag) => (
          <span class="inline-flex items-center px-3 py-1.5 bg-gray-50/70 dark:bg-white/[0.04] backdrop-blur-sm text-gray-700 dark:text-gray-300 rounded-lg text-sm font-medium border border-gray-200/60 dark:border-white/[0.06] whitespace-nowrap">
            {tag}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- 笔记大类 -->
  <section class="mb-12">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
        <img src={`${base}icons/笔记.svg`} alt="" class="w-5 h-5 icon-dark-adapt" />
        笔记
      </h2>
      <a href={`${base}garden/`} class="text-sm text-garden-600 dark:text-garden-400 hover:text-garden-500 dark:hover:text-garden-300 font-medium">
        查看全部 →
      </a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {topCategories.map((cat) => {
        const hashedSlug = registerSlug(cat.slug);
        return (
        <a
          href={`${base}garden/${hashedSlug}/`}
          class="block bg-white/50 dark:bg-[#18181b]/60 backdrop-blur-sm rounded-xl border border-gray-200/60 dark:border-white/[0.06] p-5 hover:shadow-sm hover:border-garden-300/60 dark:hover:border-garden-700/40 transition-all duration-200 group"
        >
          <div class="flex items-center gap-3 mb-2">
            <img src={`${base}icons/文件夹.svg`} alt="" class="w-5 h-5 icon-colorful" />
            <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-garden-700 dark:group-hover:text-garden-400 transition-colors">
              {cat.meta?.title || cat.title}
            </h3>
          </div>
          {cat.meta?.description && (
            <p class="text-sm text-gray-500 dark:text-gray-400 line-clamp-2">{cat.meta.description}</p>
          )}
        </a>
        );
      })}
    </div>
  </section>

  <!-- 精选项目 -->
  {featuredProjects.length > 0 && (
    <section>
      <div class="flex items-center justify-between mb-6">
        <h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2">
          <img src={`${base}icons/项目.svg`} alt="" class="w-5 h-5 icon-colorful" />
          精选项目
        </h2>
        <a href={`${base}projects/`} class="text-sm text-garden-600 dark:text-garden-400 hover:text-garden-500 dark:hover:text-garden-300 font-medium">
          查看全部 →
        </a>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {featuredProjects.map((project) => (
          <a
            href={`${base}projects/${project.id.replace(/\.md$/, '')}/`}
            class="block bg-white/50 dark:bg-[#18181b]/60 backdrop-blur-sm rounded-xl border border-gray-200/60 dark:border-white/[0.06] p-5 hover:shadow-sm hover:border-garden-300/60 dark:hover:border-garden-700/40 transition-all duration-200 group"
          >
            <div class="flex items-center justify-between mb-2">
              <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-garden-700 dark:group-hover:text-garden-400 transition-colors">
                {project.data.title}
              </h3>
              {project.stars > 0 && (
                <span class="inline-flex items-center gap-0.5 text-xs text-amber-500 dark:text-amber-400 flex-shrink-0">
                  <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                  {project.stars}
                </span>
              )}
            </div>
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-3 line-clamp-2">{project.data.description}</p>
            <div class="flex flex-wrap gap-1.5">
              {project.data.tech.map((t) => (
                <span class="bg-gray-50 dark:bg-white/[0.04] text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-md text-xs border border-gray-200/60 dark:border-white/[0.06]">{t}</span>
              ))}
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <script>
    function initHomePage() {
      // 复制到剪贴板
      document.querySelectorAll('.copy-btn').forEach(btn => {
        if ((btn as HTMLElement).dataset.bound) return;
        (btn as HTMLElement).dataset.bound = 'true';
        btn.addEventListener('click', async () => {
          const text = (btn as HTMLElement).dataset.copy;
          if (!text) return;
          try {
            await navigator.clipboard.writeText(text);
            const original = btn.innerHTML;
            btn.innerHTML = `<svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Copied!`;
            btn.classList.add('text-green-600', 'dark:text-green-400');
            setTimeout(() => {
              btn.innerHTML = original;
              btn.classList.remove('text-green-600', 'dark:text-green-400');
            }, 1500);
          } catch {
            const ta = document.createElement('textarea');
            ta.value = text;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            document.body.removeChild(ta);
          }
        });
      });
    }

    initHomePage();
    document.addEventListener('astro:page-load', initHomePage);
  </script>
</BaseLayout>
