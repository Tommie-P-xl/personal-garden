---
import Callout from '../components/mdx/Callout.astro';
import Tabs from '../components/mdx/Tabs.astro';
import TabItem from '../components/mdx/TabItem.astro';
import Collapse from '../components/mdx/Collapse.astro';
import CodeBlock from '../components/mdx/CodeBlock.astro';
import Gallery from '../components/mdx/Gallery.astro';
import Progress from '../components/mdx/Progress.astro';
import BraceMap from '../components/mdx/BraceMap.astro';
import Latex from '../components/mdx/Latex.astro';
import Table from '../components/mdx/Table.astro';
import Media from '../components/mdx/Media.astro';
import Image from '../components/mdx/Image.astro';
import '../styles/latex.css';

interface Props {
  Content: any;
  headings?: Array<{ depth: number; slug: string; text: string }>;
}

const { Content, headings } = Astro.props;

// 注册所有 MDX 组件，使其在 .mdx 文件中可用
const components = {
  Callout,
  Tabs,
  TabItem,
  Collapse,
  CodeBlock,
  Gallery,
  Progress,
  BraceMap,
  Latex,
  Table,
  Media,
  Image,
};
---

<div class="prose">
  <Content components={components} />
</div>
