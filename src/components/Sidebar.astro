---
import type { NoteFile } from '../lib/scan-notes';
import SidebarTree from './SidebarTree.astro';

interface Props {
  tree: NoteFile[];
  currentSlug: string;
  categoryTitle?: string;
}

const { tree, currentSlug, categoryTitle } = Astro.props;
const base = import.meta.env.BASE_URL;

// Collect all dir slugs that should be open (active path)
function isActive(item: NoteFile): boolean {
  if (item.type === 'file') return item.slug === currentSlug;
  return item.children?.some(child => isActive(child)) ?? false;
}

function getActiveSlugs(items: NoteFile[]): string[] {
  const slugs: string[] = [];
  for (const item of items) {
    if (item.type === 'dir') {
      if (isActive(item)) slugs.push(item.slug);
      if (item.children) slugs.push(...getActiveSlugs(item.children));
    }
  }
  return slugs;
}
const activeSlugs = getActiveSlugs(tree);

// Shared sidebar content
const sidebarContent = { tree, currentSlug, categoryTitle, base, activeSlugs };
---

{/* Desktop sidebar */}
<aside id="note-sidebar" class="hidden lg:block w-56 flex-shrink-0">
  <nav class="sticky top-20 overflow-y-auto max-h-[calc(100vh-6rem)] pr-2 pb-8">
    <div class="space-y-1">
      {categoryTitle && (
        <div class="px-3 py-2 mb-1 flex items-center gap-2">
          <img src={`${base}icons/笔记总.svg`} alt="" class="w-4 h-4 icon-colorful" />
          <span class="text-sm font-semibold text-gray-900 dark:text-white">{categoryTitle}</span>
        </div>
      )}
      <SidebarTree items={tree} currentSlug={currentSlug} />
    </div>
  </nav>
</aside>

{/* Mobile sidebar trigger */}
<button
  id="sidebar-toggle-btn"
  class="lg:hidden fixed bottom-6 right-6 z-40 p-3 rounded-full shadow-lg
    bg-garden-600 text-white hover:bg-garden-700 transition-colors"
  aria-label="打开目录"
>
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
  </svg>
</button>

{/* Mobile overlay */}
<div id="sidebar-overlay" class="lg:hidden fixed inset-0 bg-black/50 z-40 hidden"></div>

{/* Mobile drawer */}
<div id="sidebar-drawer" class="lg:hidden fixed top-0 left-0 bottom-0 w-72 bg-white/80 dark:bg-[#0f1117]/80 backdrop-blur-xl z-50 transform -translate-x-full transition-transform overflow-y-auto border-r border-gray-200/50 dark:border-white/[0.06]">
  <div class="p-4">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold text-gray-900 dark:text-white">目录</h2>
      <button id="sidebar-close-btn" class="p-2 rounded-lg text-gray-600 dark:text-gray-300 hover:bg-gray-100/60 dark:hover:bg-white/[0.06]">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <nav class="space-y-1">
      {categoryTitle && (
        <div class="px-3 py-2 mb-1 flex items-center gap-2">
          <img src={`${base}icons/笔记总.svg`} alt="" class="w-4 h-4 icon-colorful" />
          <span class="text-sm font-semibold text-gray-900 dark:text-white">{categoryTitle}</span>
        </div>
      )}
      <SidebarTree items={tree} currentSlug={currentSlug} />
    </nav>
  </div>
</div>

<!-- Pass server-computed active slugs to client -->
<script is:inline define:vars={{ activeSlugs }}>
  window.__sidebarActiveSlugs = activeSlugs;
</script>

<script is:inline>
  (function() {
    var STORAGE_KEY = 'sidebar-open-slugs';

    function getOpenSlugs() {
      try {
        var saved = localStorage.getItem(STORAGE_KEY);
        if (saved) return new Set(JSON.parse(saved));
      } catch {}
      return new Set(window.__sidebarActiveSlugs || []);
    }

    function saveOpenSlugs(slugs) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(Array.from(slugs)));
    }

    function applySidebarState() {
      var openSlugs = getOpenSlugs();
      document.querySelectorAll('.sidebar-toggle').forEach(function(btn) {
        var slug = btn.dataset.slug;
        var children = btn.nextElementSibling;
        var chevron = btn.querySelector('.chevron');
        if (!children || !slug) return;
        var isOpen = openSlugs.has(slug);
        children.classList.toggle('hidden', !isOpen);
        if (chevron) chevron.classList.toggle('rotate-90', isOpen);
      });
    }

    function bindSidebarToggles() {
      document.querySelectorAll('.sidebar-toggle').forEach(function(btn) {
        if (btn.dataset.bound) return;
        btn.dataset.bound = 'true';
        btn.addEventListener('click', function() {
          var slug = btn.dataset.slug;
          var children = btn.nextElementSibling;
          var chevron = btn.querySelector('.chevron');
          if (!children || !slug) return;
          var openSlugs = getOpenSlugs();
          var isNowHidden = children.classList.toggle('hidden');
          if (chevron) chevron.classList.toggle('rotate-90', !isNowHidden);
          if (isNowHidden) { openSlugs.delete(slug); }
          else { openSlugs.add(slug); }
          saveOpenSlugs(openSlugs);
        });
      });
    }

    function bindMobileSidebar() {
      var toggleBtn = document.getElementById('sidebar-toggle-btn');
      var overlay = document.getElementById('sidebar-overlay');
      var drawer = document.getElementById('sidebar-drawer');
      var closeBtn = document.getElementById('sidebar-close-btn');
      if (!toggleBtn || toggleBtn.dataset.bound) return;
      toggleBtn.dataset.bound = 'true';
      toggleBtn.addEventListener('click', function() {
        overlay?.classList.remove('hidden');
        drawer?.classList.remove('-translate-x-full');
      });
      overlay?.addEventListener('click', function() {
        overlay.classList.add('hidden');
        drawer?.classList.add('-translate-x-full');
      });
      closeBtn?.addEventListener('click', function() {
        overlay?.classList.add('hidden');
        drawer?.classList.add('-translate-x-full');
      });
    }

    function initSidebar() {
      applySidebarState();
      bindSidebarToggles();
      bindMobileSidebar();
    }

    initSidebar();
    document.addEventListener('astro:page-load', initSidebar);
  })();
</script>

<style>
  /* 侧边栏子菜单竖线 */
  .sidebar-children:not(.hidden) {
    position: relative;
    margin-left: 12px;
    padding-left: 14px;
  }

  .sidebar-children:not(.hidden)::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 2px;
    background-color: #94a3b8;
    border-radius: 1px;
  }

  html.dark .sidebar-children:not(.hidden)::before {
    background-color: rgba(255, 255, 255, 0.2);
  }

  .sidebar-children:not(.hidden):has(.bg-garden-50)::before {
    background-color: #6366f1;
  }

  html.dark .sidebar-children:not(.hidden):has(.dark\:bg-garden-900\/20)::before {
    background-color: #818cf8;
  }

  /* 嵌套的子菜单 - 稍浅的竖线 */
  .sidebar-subgroup .sidebar-children:not(.hidden) {
    margin-left: 12px;
  }

  .sidebar-subgroup .sidebar-children:not(.hidden)::before {
    background-color: #cbd5e1;
    width: 2px;
  }

  html.dark .sidebar-subgroup .sidebar-children:not(.hidden)::before {
    background-color: rgba(255, 255, 255, 0.12);
  }

  .sidebar-subgroup .sidebar-children:not(.hidden):has(.bg-garden-50)::before {
    background-color: #6366f1;
  }

  html.dark .sidebar-subgroup .sidebar-children:not(.hidden):has(.dark\:bg-garden-900\/20)::before {
    background-color: #818cf8;
  }
</style>
