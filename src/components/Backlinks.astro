---
interface Props {
  backlinks: Array<{
    title: string;
    slug: string;
    summary?: string;
  }>;
}

const { backlinks } = Astro.props;
const base = import.meta.env.BASE_URL;
---

{backlinks.length > 0 && (
  <div class="mt-8 pt-6 border-t border-gray-200/60 dark:border-white/[0.06]">
    <h3 class="text-base font-semibold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
      <svg class="w-4 h-4 text-garden-600 dark:text-garden-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg>
      被以下笔记引用
    </h3>
    <div class="grid gap-3 sm:grid-cols-2">
      {backlinks.map((note) => (
        <a
          href={`${base}garden/${note.slug}/`}
          class="block p-3 bg-gray-50/70 dark:bg-white/[0.04] backdrop-blur-sm rounded-lg hover:bg-garden-50/50 dark:hover:bg-garden-900/10 transition-colors border border-gray-200/60 dark:border-white/[0.06]"
        >
          <div class="font-medium text-gray-900 dark:text-white text-sm">{note.title}</div>
          {note.summary && (
            <div class="text-xs text-gray-500 dark:text-gray-400 mt-1 line-clamp-2">{note.summary}</div>
          )}
        </a>
      ))}
    </div>
  </div>
)}
