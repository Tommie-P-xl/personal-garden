---
interface Props {
  title?: string;
  showLineNumbers?: boolean;
  highlightLines?: string;
}

const { title, showLineNumbers = false, highlightLines } = Astro.props;

// 解析高亮行号，如 "1,3-5" => [1, 3, 4, 5]
function parseHighlightLines(lines: string | undefined): number[] {
  if (!lines) return [];
  const result: number[] = [];
  lines.split(',').forEach((part) => {
    if (part.includes('-')) {
      const [start, end] = part.split('-').map(Number);
      for (let i = start; i <= end; i++) result.push(i);
    } else {
      result.push(Number(part));
    }
  });
  return result;
}

const highlightedLines = parseHighlightLines(highlightLines);
---

<div class="my-4 rounded-lg border border-gray-200/60 dark:border-white/[0.06] overflow-hidden">
  {title && (
    <div class="flex items-center gap-2 px-4 py-2 bg-gray-100 dark:bg-gray-800 border-b border-gray-200/60 dark:border-white/[0.06]">
      <div class="flex gap-1.5">
        <span class="w-3 h-3 rounded-full bg-red-400 dark:bg-red-500" />
        <span class="w-3 h-3 rounded-full bg-yellow-400 dark:bg-yellow-500" />
        <span class="w-3 h-3 rounded-full bg-green-400 dark:bg-green-500" />
      </div>
      <span class="text-xs text-gray-500 dark:text-gray-400 font-mono ml-2">{title}</span>
    </div>
  )}
  <div class="relative">
    {showLineNumbers && (
      <div class="absolute left-0 top-0 bottom-0 w-10 bg-gray-50 dark:bg-gray-800/50 border-r border-gray-200/60 dark:border-white/[0.06] select-none" />
    )}
    <div class="overflow-x-auto">
      <slot />
    </div>
  </div>
</div>
