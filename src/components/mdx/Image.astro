---
// src/components/mdx/Image.astro
import path from 'node:path';
import fs from 'node:fs';

interface Props {
  /** 图片源路径（相对于当前笔记的 _media 目录） */
  src: string;
  /** 替代文本 */
  alt?: string;
  /** 宽度 */
  width?: string;
  /** 高度 */
  height?: string;
  /** 对齐方式 */
  align?: 'left' | 'center' | 'right';
  /** 标题说明 */
  caption?: string;
}

const {
  src,
  alt = '',
  width,
  height,
  align = 'center',
  caption
} = Astro.props;

const base = import.meta.env.BASE_URL;
const NOTES_DIR = path.resolve('src/content/notes');
const PUBLIC_MEDIA = path.resolve('public/media');

// 解析图片路径 - 使用与remark-media相同的逻辑
function resolveImagePath(srcPath: string): string {
  // 如果已经是绝对路径或外部URL，直接返回
  if (srcPath.startsWith('http://') || srcPath.startsWith('https://') || srcPath.startsWith('/')) {
    return srcPath;
  }

  // 从当前页面URL提取笔记路径信息
  const pagePath = Astro.url.pathname;
  // URL格式: /personal-garden/garden/{hash}/

  // 扫描public/media目录，找到所有媒体文件
  // 然后根据相对路径规则匹配正确的文件
  function findMediaFile(basePath: string, relativePath: string): string | null {
    // 解析相对路径
    let targetPath = relativePath;
    if (relativePath.startsWith('./')) {
      targetPath = relativePath.slice(2);
    }

    // 在public/media目录中搜索
    function searchDir(dir: string, prefix: string): string | null {
      if (!fs.existsSync(dir)) return null;

      const entries = fs.readdirSync(dir, { withFileTypes: true });
      for (const entry of entries) {
        const fullPath = path.join(dir, entry.name);
        const relativePath = prefix ? `${prefix}/${entry.name}` : entry.name;

        if (entry.isDirectory()) {
          const found = searchDir(fullPath, relativePath);
          if (found) return found;
        } else {
          // 检查文件路径是否匹配
          // 例如：./_media/test-icon.svg 应该匹配 0004-mdx-components/_media/test-icon.svg
          if (relativePath.endsWith(targetPath) || targetPath.endsWith(entry.name)) {
            return `media/${relativePath}`;
          }
        }
      }
      return null;
    }

    return searchDir(basePath, '');
  }

  const result = findMediaFile(PUBLIC_MEDIA, srcPath);
  if (result) {
    return `${base}${result}`;
  }

  // 如果找不到，返回原始路径
  return srcPath;
}

const processedSrc = resolveImagePath(src);

const sizeStyle = [
  width ? `width: ${width}` : '',
  height ? `height: ${height}` : '',
].filter(Boolean).join('; ');

const alignClasses = {
  left: 'image-align-left',
  center: 'image-align-center',
  right: 'image-align-right',
};
---

<figure class:list={['image-wrapper', alignClasses[align]]}>
  <img
    src={processedSrc}
    alt={alt}
    class="image-element"
    style={sizeStyle || undefined}
    loading="lazy"
  />
  {caption && <figcaption class="image-caption">{caption}</figcaption>}
</figure>

<style>
  .image-wrapper {
    @apply my-6;
  }

  .image-align-left {
    text-align: left;
  }

  .image-align-center {
    text-align: center;
  }

  .image-align-right {
    text-align: right;
  }

  .image-element {
    @apply rounded-lg shadow-md;
    max-width: 100%;
    height: auto;
    display: inline-block;
  }

  .image-align-left .image-element {
    display: block;
    margin-left: 0;
    margin-right: auto;
  }

  .image-align-center .image-element {
    display: block;
    margin-left: auto;
    margin-right: auto;
  }

  .image-align-right .image-element {
    display: block;
    margin-left: auto;
    margin-right: 0;
  }

  .image-caption {
    @apply text-sm text-gray-500 dark:text-gray-400 mt-2 italic;
  }

  .image-align-left .image-caption {
    text-align: left;
  }

  .image-align-center .image-caption {
    text-align: center;
  }

  .image-align-right .image-caption {
    text-align: right;
  }
</style>
