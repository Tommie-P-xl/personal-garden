---
interface Props {
  title: string;
  description: string;
  tech: string[];
  link?: string;
  github?: string;
  image?: string;
  date: Date;
  slug?: string;
  stars?: number;
}

const { title, description, tech, link, github, image, date, slug, stars } = Astro.props;
const base = import.meta.env.BASE_URL;

const dateStr = date instanceof Date
  ? date.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit' })
  : date;

const detailHref = slug ? `${base}projects/${slug}/` : null;
---

<div class="relative bg-white/60 dark:bg-[#141827]/60 backdrop-blur-xl rounded-xl border border-gray-200/50 dark:border-white/[0.06] overflow-hidden hover:shadow-md hover:border-garden-300/60 dark:hover:border-garden-700/30 transition-all duration-300 group">
  {detailHref && (
    <a href={detailHref} class="absolute inset-0 z-10" aria-label={title}>
      <span class="sr-only">{title}</span>
    </a>
  )}

  {image && (
    <div class="aspect-video bg-gray-50 dark:bg-white/[0.02] overflow-hidden">
      <img src={image} alt={title} class="w-full h-full object-cover group-hover:scale-[1.02] transition-transform duration-300" />
    </div>
  )}

  <div class="p-5">
    <div class="flex items-start justify-between gap-2 mb-2">
      <h3 class="text-base font-semibold text-gray-900 dark:text-white group-hover:text-garden-600 dark:group-hover:text-garden-400 transition-colors">{title}</h3>
      <div class="flex items-center gap-2 flex-shrink-0">
        {stars !== undefined && stars > 0 && (
          <span class="inline-flex items-center gap-0.5 text-xs text-amber-500 dark:text-amber-400">
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            {stars}
          </span>
        )}
        <span class="text-xs text-gray-400 dark:text-gray-500 tabular-nums">{dateStr}</span>
      </div>
    </div>

    <p class="text-sm text-gray-500 dark:text-gray-400 mb-4 line-clamp-3">{description}</p>

    <div class="flex items-center justify-between relative z-20">
      <div class="flex flex-wrap gap-1.5">
        {tech.map((t) => (
          <span class="bg-gray-50/80 dark:bg-white/[0.04] text-gray-600 dark:text-gray-400 px-2 py-0.5 rounded-md text-xs font-medium border border-gray-200/50 dark:border-white/[0.06]">{t}</span>
        ))}
      </div>

      <div class="flex gap-2">
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-20 text-gray-400 dark:text-gray-500 hover:text-gray-700 dark:hover:text-gray-300 transition-colors"
            title="GitHub"
          >
            <svg class="w-[18px] h-[18px]" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
            </svg>
          </a>
        )}
        {link && (
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="relative z-20 text-gray-400 dark:text-gray-500 hover:text-garden-600 dark:hover:text-garden-400 transition-colors"
            title="访问链接"
          >
            <svg class="w-[18px] h-[18px]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>
</div>
